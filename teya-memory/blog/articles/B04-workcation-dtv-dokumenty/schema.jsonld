      "mainEntity": [
        {
          "@type": "Question",
          "name": "Нужен ли перевод договора на английский?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от требований консульства на thaievisa.go.th. Часто принимают английский или тайский."
          }
        },
        {
          "@type": "Question",
          "name": "Достаточно ли ИП в России для Workcation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ИП с контрактами и поступлениями может подходить, если документы показывают удалённый доход из-за рубежа Таиланда."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли показать криптовалютный доход?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Только если он отражён в официальной банковской выписке и принимается консульством."
          }
        },
        {
          "@type": "Question",
          "name": "Нужно ли письмо от работодателя на английском?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Рекомендуется. Письмо должно подтверждать remote work."
          }
        },
        {
          "@type": "Question",
          "name": "Что указать в портфолио, если NDA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Опишите тип проектов без раскрытия секретов. Приложите контракты где NDA позволяет."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько контрактов приложить фрилансеру?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Обычно достаточно от 2 до 3 актуальных с поступлениями за последние месяцы."
          }
        },
        {
          "@type": "Question",
