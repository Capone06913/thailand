        {
          "@type": "HowToStep",
          "name": "Регистрация на thaievisa.go.th",
          "text": "Создайте учётную запись на официальном портале Thai e-Visa на рабочий email."
        },
        {
          "@type": "HowToStep",
          "name": "Выбор консульства и типа визы",
          "text": "Укажите VAC или консульство, тип визы TR или DTV и подкатегорию."
        },
        {
          "@type": "HowToStep",
          "name": "Заполнение анкеты",
          "text": "Введите данные паспорта, цель поездки и даты въезда и выезда."
        },
        {
          "@type": "HowToStep",
          "name": "Загрузка документов",
          "text": "Прикрепите PDF-сканы по чек-листу выбранной категории визы."
        },
        {
          "@type": "HowToStep",
          "name": "Оплата и запись в VAC",
          "text": "Оплатите госпошлину и запишитесь на визит, если он обязателен."
        }
      ]
