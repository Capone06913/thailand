    {
      "@type": "FAQPage",
      "@id": "https://thaipass.ru/blog/thaievisa-podacha-poshagovo#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Можно ли подать thaievisa из России?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, если выбранное консульство или VAC принимает заявления от резидентов РФ. Маршрут уточняйте на thaievisa.go.th и moscow.thaiembassy.org на дату подачи."
          }
        },
        {
          "@type": "Question",
          "name": "Нужен ли личный визит при подаче через thaievisa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от типа визы и выбранного VAC. Портал покажет, нужна ли запись на биометрию после оплаты."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько длится рассмотрение после подачи на thaievisa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Срок не фиксирован: от нескольких дней до нескольких недель. Зависит от консульства, сезона и полноты пакета."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли редактировать анкету после оплаты?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Обычно существенные правки: через запрос консульства или новую заявку. Проверяйте анкету до платежа."
          }
        },
        {
          "@type": "Question",
          "name": "Thaievisa заменяет TDAC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. Виза оформляется на thaievisa; TDAC заполняется отдельно перед каждым въездом на tdac.immigration.go.th."
          }
        },
        {
          "@type": "Question",
          "name": "Где посмотреть актуальную госпошлину?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Только на thaievisa.go.th и в инструкции выбранного консульства на дату подачи."
          }
        },
        {
          "@type": "Question",
          "name": "Помогает ли ThaiPass с подачей на thaievisa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, через DTV Concierge и аудит документов. Решение по визе принимает только консульство Таиланда."
          }
        }
      ]
