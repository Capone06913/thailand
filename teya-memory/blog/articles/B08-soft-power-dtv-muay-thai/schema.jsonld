      "mainEntity": [
        {
          "@type": "Question",
          "name": "Любая школа Muay Thai подходит для DTV?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. Нужна организация, которая соответствует требованиям категории Soft Power на thaievisa и выдаёт документы для консульства."
          }
        },
        {
          "@type": "Question",
          "name": "Нужны ли 500 000 бат на тайском счёте?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Обычно достаточно эквивалента на счёте в другой валюте по правилам консульства."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли работать удалённо на Soft Power Muay Thai?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Soft Power завязан на обучение. Удалённая работа: отдельная категория Workcation."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько длится рассмотрение DTV Muay Thai?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Как у других DTV: от нескольких недель, зависит от консульства и сезона."
          }
        },
        {
          "@type": "Question",
          "name": "Чем Soft Power отличается от туристической TR?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TR: туризм без 500k и без долгосрочной программы обучения. DTV Soft Power: длительное пребывание с договором школы."
          }
        },
        {
          "@type": "Question",
          "name": "Что делать, если школа отказала в письме для визы?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ищите другую школу или меняйте маршрут. Без документов школы Soft Power не собрать."
          }
        },
        {
          "@type": "Question",
          "name": "Помогает ли ThaiPass с DTV Muay Thai?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, через DTV Audit и Concierge. Визу выдаёт только консульство."
