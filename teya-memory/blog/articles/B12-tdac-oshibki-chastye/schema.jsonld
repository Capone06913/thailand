    {
      "@type": "FAQPage",
      "@id": "https://thaipass.ru/blog/tdac-oshibki-chastye#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Можно ли заполнить TDAC за неделю до вылета?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. Окно открывается не ранее чем за 72 часа до прибытия в Таиланд."
          }
        },
        {
          "@type": "Question",
          "name": "Нужна ли TDAC детям?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, каждый въезжающий подаёт отдельную карту, если иное не указано на официальном портале."
          }
        },
        {
          "@type": "Question",
          "name": "TDAC заменяет визу?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. TDAC: карта прибытия; виза или безвиз: отдельный правовой режим."
          }
        },
        {
          "@type": "Question",
          "name": "Что делать, если нашёл опечатку после отправки?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Используйте функцию исправления или подайте новую TDAC по правилам tdac.immigration.go.th до вылета."
          }
        },
        {
          "@type": "Question",
          "name": "Штрафуют ли за отсутствие TDAC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TDAC обязательна; последствия уточняйте в официальных объявлениях иммиграции."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли заполнить TDAC на русском?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Интерфейс многоязычный; персональные данные: как в паспорте латиницей."
          }
        },
        {
          "@type": "Question",
          "name": "Помогает ли ThaiPass с TDAC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ThaiPass фокусируется на визовом сопровождении. TDAC заполняется самостоятельно на государственном портале."
          }
        }
      ]
    }
