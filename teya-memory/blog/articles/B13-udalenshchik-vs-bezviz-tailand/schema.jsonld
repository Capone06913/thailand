      "mainEntity": [
        {
          "@type": "Question",
          "name": "Можно ли легально работать удалённо на безвизе?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Безвиз: туристический статус. Удалённая работа не оформлена; для формализации: DTV Workcation."
          }
        },
        {
          "@type": "Question",
          "name": "Нужен ли DTV, если работодатель в другой стране?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "При проживании в Таиланде месяцами DTV Workcation подтверждает цель пребывания. Краткий визит: безвиз."
          }
        },
        {
          "@type": "Question",
          "name": "DTV требует 500 000 бат на тайском счёте?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Обычно достаточно эквивалента на счёте в другой валюте по правилам консульства."
          }
        },
        {
          "@type": "Question",
          "name": "Чем DTV лучше туристической TR для фрилансера?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TR не предполагает удалённую работу как цель. DTV Workcation включает проверку контрактов и выписки."
          }
        },
        {
          "@type": "Question",
          "name": "Border run заменяет DTV?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. Повторные въезды не дают долгосрочного статуса удалёнщика."
          }
        },
        {
          "@type": "Question",
          "name": "ThaiPass гарантирует DTV?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. Решение принимает консульство."
          }
        },
        {
          "@type": "Question",
          "name": "Нужна ли TDAC при DTV?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, TDAC обязательна для каждого въезда."
