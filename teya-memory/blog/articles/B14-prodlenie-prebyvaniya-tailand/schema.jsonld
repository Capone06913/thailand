      "mainEntity": [
        {
          "@type": "Question",
          "name": "Можно ли продлить безвиз в иммиграции?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от типа въезда и правил на дату обращения. Уточняйте в местном IMMI."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько раз продлевают туристическую TR?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Лимиты задаёт иммиграция; бесконечное продление: миф."
          }
        },
        {
          "@type": "Question",
          "name": "Border run продлевает безвиз легально?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Новый въезд даёт новый stamp, но злоупотребление въездами может привести к отказу."
          }
        },
        {
          "@type": "Question",
          "name": "Что такое 90-day report?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Обязанность сообщать адрес каждые 90 дней для долгосрочных категорий."
          }
        },
        {
          "@type": "Question",
          "name": "Штраф за overstay?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, размер зависит от количества дней просрочки."
          }
        },
        {
          "@type": "Question",
          "name": "Может ли ThaiPass продлить визу в IMMI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Продление: личная процедура заявителя в Таиланде."
          }
        },
        {
          "@type": "Question",
          "name": "Нужна ли TDAC при выезде и новом въезде?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TDAC заполняется на каждый новый въезд в окне 72 часов."
          }
        }
      ]
