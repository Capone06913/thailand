      "mainEntity": [
        {
          "@type": "Question",
          "name": "Где подать на визу в Таиланд из России?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Основной маршрут: Thai e-Visa на thaievisa.go.th с jurisdiction Royal Thai Embassy Moscow."
          }
        },
        {
          "@type": "Question",
          "name": "Нужно ли лично приезжать в посольство?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от типа визы и этапа e-Visa. Портал покажет, нужен ли визит или VAC."
          }
        },
        {
          "@type": "Question",
          "name": "ThaiPass: это посольство?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. ThaiPass: частный сервис сопровождения документов."
          }
        },
        {
          "@type": "Question",
          "name": "Как связаться с посольством?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Контакты: на moscow.thaiembassy.org."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли подать DTV через Москву?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Если консульский округ принимает DTV от резидентов РФ: да, через thaievisa."
          }
        },
        {
          "@type": "Question",
          "name": "Где адрес ThaiPass в Москве?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Актуальный адрес: на странице kontakty ThaiPass."
          }
        },
        {
          "@type": "Question",
          "name": "Нужна ли TDAC после получения визы?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да. TDAC заполняется не ранее чем за 72 часа до каждого прилёта."
          }
        }
      ]
