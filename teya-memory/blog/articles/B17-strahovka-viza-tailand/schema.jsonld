      "mainEntity": [
        {
          "@type": "Question",
          "name": "Обязательна ли страховка для туристической визы TR?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Для большинства заявок через thaievisa медстраховка требуется по чек-листу категории."
          }
        },
        {
          "@type": "Question",
          "name": "Какая минимальная сумма покрытия?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от типа визы и jurisdiction; смотрите thaievisa на дату подачи."
          }
        },
        {
          "@type": "Question",
          "name": "Подойдёт ли полис из банка бесплатно к карте?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Только если certificate соответствует сроку, территории и сумме по чек-листу."
          }
        },
        {
          "@type": "Question",
          "name": "ThaiPass продаёт страховку?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ThaiPass не страховая компания; помогает подобрать полис в визовых пакетах."
          }
        },
        {
          "@type": "Question",
          "name": "Нужно ли обновлять страховку при продлении в IMMI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Часто да: полис должен покрывать новый период stay."
          }
        },
        {
          "@type": "Question",
          "name": "Страховка заменяет финансовую выписку для DTV?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет. DTV требует отдельный пакет с финансами и страховкой."
          }
        },
        {
          "@type": "Question",
          "name": "Что загружать в e-Visa: полис или чек?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Официальный PDF insurance certificate с данными застрахованного."
          }
        }
      ]
