      "@type": "FAQPage",
      "@id": "https://thaipass.ru/blog/konsulstva-tailanda-rossiya#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Где консульства Таиланда для россиян?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Основная jurisdiction: Royal Thai Embassy Moscow через thaievisa.go.th. VAC и запись: в личном кабинете."
          }
        },
        {
          "@type": "Question",
          "name": "Чем VAC отличается от посольства?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "VAC принимает паспорт и биометрию; решение по визе принимает консульство."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли подать из Петербурга или регионов?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Анкета онлайн из любого города РФ; очный этап по назначенному VAC или embassy."
          }
        },
        {
          "@type": "Question",
          "name": "Как выбрать правильный консульский округ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "При регистрации на thaievisa укажите резидентство; для большинства россиян Moscow jurisdiction."
          }
        },
        {
          "@type": "Question",
          "name": "ThaiPass подаёт в консульство за меня?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ThaiPass готовит документы; биометрию и паспорт в VAC передаёте вы по правилам embassy."
          }
        },
        {
          "@type": "Question",
          "name": "Нужно ли ехать в посольство, если есть VAC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зависит от шагов в личном кабинете e-Visa для вашего кейса."
          }
        },
        {
          "@type": "Question",
          "name": "Где официальные правила для россиян?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "moscow.thaiembassy.org и thaievisa.go.th."
          }
        }
      ]
    }
